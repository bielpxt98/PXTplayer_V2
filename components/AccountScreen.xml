<?xml version="1.0" encoding="utf-8" ?>
<component name="AccountScreen" extends="Group">
  <interface>
    <field id="backRequested" type="boolean" alwaysNotify="true" />
    <field id="removeRequested" type="boolean" alwaysNotify="true" />
    <field id="account" type="assocarray" onChange="onAccountChanged" />
    <function name="setAccountFocus" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/AccountScreen.brs" />
  <children>
    <Rectangle id="background" color="0x000000FF" />
    <Label id="titleLabel" text="CONTA" color="0xFFFFFFFF" horizAlign="center" font="font:LargeBoldSystemFont" />
    <Group id="contentGroup">
      <Label id="serverLabel" color="0xD8E6FFFF" font="font:MediumSystemFont" />
      <Label id="userLabel" color="0xD8E6FFFF" font="font:MediumSystemFont" />
      <Label id="statusLabel" color="0xD8E6FFFF" font="font:MediumSystemFont" />
      <HomeButton id="removeButton" labelText="REMOVER CONTA" />
      <HomeButton id="backButton" labelText="VOLTAR" />
    </Group>
  </children>
</component>
