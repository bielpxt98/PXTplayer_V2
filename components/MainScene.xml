<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
  <script type="text/brightscript" uri="pkg:/source/PlaylistStorage.brs" />
  <children>
    <Rectangle id="background" width="1920" height="1080" color="#101014" />
    <HomeScreen id="home" visible="false" />
    <LoginScreen id="login" visible="false" />
    <Group id="loading" visible="false">
      <Label text="PXT Player" translation="[120,90]" color="#FFFFFF" font="font:LargeBoldSystemFont" />
      <Label id="loadingTitle" text="Conectando..." translation="[120,230]" color="#FFFFFF" font="font:LargeBoldSystemFont" />
      <Label id="loadingStatus" text="Conectando..." translation="[120,310]" width="1200" height="220" wrap="true" color="#FFFFFF" font="font:MediumSystemFont" />
      <Label id="loadingHint" text="Aguarde enquanto validamos o login." translation="[120,370]" width="1300" color="#B8B8C8" font="font:MediumSystemFont" />
    </Group>
    <XtreamService id="startupService" />
    <Timer id="startupTimeout" repeat="false" duration="35" />
    <Timer id="startupSuccessDelay" repeat="false" duration="0.8" />
  </children>
</component>
