<?xml version="1.0" encoding="utf-8" ?>
<component name="LoadingScreen" extends="Group">
  <interface>
    <field id="loadingFinished" type="boolean" alwaysNotify="true" />
    <function name="startLoading" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/LoadingScreen.brs" />
  <children>
    <Rectangle id="background" color="0x000000FF" />
    <Label id="titleLabel" text="PXT PLAYER" color="0xFFFFFFFF" horizAlign="center" font="font:LargeBoldSystemFont" />
    <Label id="subtitleLabel" text="Preparando sua lista..." color="0xD8E6FFFF" horizAlign="center" font="font:MediumSystemFont" />

    <Group id="stepsGroup">
      <Label id="connectLabel" text="Conectando ao servidor..." color="0xFFFFFFFF" font="font:MediumSystemFont" />
      <Label id="connectStatus" text="" color="0x33DD77FF" horizAlign="right" font="font:MediumBoldSystemFont" />
      <Label id="liveLabel" text="Carregando TV ao vivo..." color="0xA8B7CCFF" font="font:MediumSystemFont" />
      <Label id="liveStatus" text="" color="0x33DD77FF" horizAlign="right" font="font:MediumBoldSystemFont" />
      <Label id="moviesLabel" text="Carregando Filmes..." color="0xA8B7CCFF" font="font:MediumSystemFont" />
      <Label id="moviesStatus" text="" color="0x33DD77FF" horizAlign="right" font="font:MediumBoldSystemFont" />
      <Label id="seriesLabel" text="Carregando Séries..." color="0xA8B7CCFF" font="font:MediumSystemFont" />
      <Label id="seriesStatus" text="" color="0x33DD77FF" horizAlign="right" font="font:MediumBoldSystemFont" />
      <Label id="finishLabel" text="Finalizando..." color="0xA8B7CCFF" font="font:MediumSystemFont" />
      <Label id="finishStatus" text="" color="0x33DD77FF" horizAlign="right" font="font:MediumBoldSystemFont" />
    </Group>

    <Timer id="stepTimer" duration="0.35" repeat="false" />
  </children>
</component>
