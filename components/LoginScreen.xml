<?xml version="1.0" encoding="utf-8" ?>
<component name="LoginScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/source/KeyNormalizer.brs" />
  <script type="text/brightscript" uri="pkg:/components/LoginScreen.brs" />
  <script type="text/brightscript" uri="pkg:/source/PlaylistStorage.brs" />
  <interface>
    <field id="closeLogin" type="boolean" alwaysNotify="true" />
    <field id="loginSuccess" type="boolean" alwaysNotify="true" />
    <function name="resetStatus" />
    <function name="setStatus" />
  </interface>
  <children>
    <Label text="Login Xtream" translation="[120,70]" color="#FFFFFF" font="font:LargeBoldSystemFont" />

    <Label text="DNS" translation="[120,160]" color="#FFFFFF" font="font:MediumBoldSystemFont" />
    <TextEditBox id="dnsInput" translation="[120,205]" width="1120" height="72" hintText="http://servidor:porta" maxTextLength="512" />

    <Label text="USUÁRIO" translation="[120,305]" color="#FFFFFF" font="font:MediumBoldSystemFont" />
    <TextEditBox id="usernameInput" translation="[120,350]" width="720" height="72" hintText="Usuário" maxTextLength="128" />

    <Label text="SENHA" translation="[120,450]" color="#FFFFFF" font="font:MediumBoldSystemFont" />
    <TextEditBox id="passwordInput" translation="[120,495]" width="720" height="72" hintText="Senha" maxTextLength="128" />

    <Label id="status" translation="[120,585]" width="1040" height="40" wrap="true" color="#FFFFFF" font="font:MediumSystemFont" />

    <Rectangle id="enterBg" translation="[120,630]" width="260" height="64" color="#243B65" />
    <Label id="enterLabel" text="ENTRAR" translation="[182,649]" color="#FFFFFF" font="font:MediumBoldSystemFont" />

    <Rectangle id="backBg" translation="[420,630]" width="260" height="64" color="#303038" />
    <Label id="backLabel" text="VOLTAR" translation="[485,649]" color="#FFFFFF" font="font:MediumBoldSystemFont" />

    <XtreamService id="service" />
  </children>
</component>
